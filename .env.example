# ═══ CRYPTOPREDICT CONTRACTS — ENV ═══

# Chiave privata del wallet deployer (senza 0x)
# ⚠️ MAI committare il .env reale su GitHub
DEPLOYER_PRIVATE_KEY=la-tua-chiave-privata-senza-0x

# RPC Base Sepolia
BASE_SEPOLIA_RPC=https://sepolia.base.org

# BaseScan API key per la verifica dei contratti (opzionale)
# Ottienila su https://basescan.org/myapikey
BASESCAN_API_KEY=

# Indirizzi contratti (dopo il deploy)
CPRED_TOKEN_ADDRESS=
PREDICTION_MARKET_ADDRESS=
PRESALE_ADDRESS=
